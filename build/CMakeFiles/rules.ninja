#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = /opt/esp/tools/cmake/4.0.3/bin/cmake --regenerate-during-build -S/workspaces/mp3_esp32_fw -B/workspaces/mp3_esp32_fw/build
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning additional files.

rule CLEAN_ADDITIONAL
  command = /opt/esp/tools/cmake/4.0.3/bin/cmake -DCONFIG=$CONFIG -P CMakeFiles/clean_additional.cmake
  description = Cleaning additional files...


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = /usr/bin/ninja $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = /usr/bin/ninja -t targets
  description = All primary targets available:

